{
    "inputs": [],
    "servers": {
        "github": {
            "type": "http",
            "url": "https://api.githubcopilot.com/mcp/"
        },
        "com.atlassian/atlassian-mcp-server": {
            "type": "http",
            "url": "https://mcp.atlassian.com/v1/mcp",
            "gallery": "https://api.mcp.github.com",
            "version": "1.1.2"
        },
        "mcp-server-linkedin": {
            "command": "uvx",
            "args": [
                "mcp-server-linkedin@latest"
            ],
            "env": {
                "UV_HTTP_TIMEOUT": "300"
            }
        },
        "notion": {
            "type": "http",
            "url": "https://mcp.notion.com/mcp"
        }
    }
}